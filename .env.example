# Copy to .env and fill in. Never commit .env.

# ENTSO-E Transparency Web API token (https://transparency.entsoe.eu/)
# Used by ``trading_pipeline_utils.entsoe_data`` fetchers.
# ENTSOE_TOKEN=your-entsoe-security-token
# Optional: override API base (default https://web-api.tp.entsoe.eu/api)
# ENTSOE_API_BASE=

# Gemini API key for LLM QA and desk commentary insights
# Get your key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-api-key-here

# LLM_QA=0   # set to 0/false/off to fetch only (no LLM calls) even if key is present
