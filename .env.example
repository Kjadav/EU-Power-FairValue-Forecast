# Copy to .env and fill in. Never commit .env.

# Example: API keys for public or licensed data feeds (ENTSO-E, etc.)
# ENTSOE_TOKEN=

# Optional: OpenAI for SMARD bundle LLM QA (scripts/run_ingestion.py enables LLM when key is set)
# OPENAI_API_KEY=sk-...
# LLM_QA=0   # set to 0/false/off to fetch only (no OpenAI calls) even if key is present

# ANTHROPIC_API_KEY=
